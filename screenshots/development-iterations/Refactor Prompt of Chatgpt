============================================================
REQUIRED MASTER PROFILE SCHEMA
============================================================

Create strict TypeScript types/interfaces.

Use this schema as the source of truth:

type ResumeProfile = {
  personal: PersonalInfo;
  summary: ProfileSummary;
  education: EducationEntry[];
  experience: ExperienceEntry[];
  projects: ProjectEntry[];
  skills: SkillsProfile;
  certifications: CertificationEntry[];
  volunteerWork: VolunteerEntry[];
  awards: AwardEntry[];
  languages: LanguageEntry[];
};

type PersonalInfo = {
  fullName: string;
  email: string;
  phone: string;
  location: string;
  githubUrl: string;
  linkedinUrl: string;
  portfolioUrl?: string;
};

type ProfileSummary = {
  targetRole?: string;
  about: string;
  yearsOfExperience?: string;
};

type EducationEntry = {
  id: string;
  institution: string;
  degree: string;
  fieldOfStudy: string;
  startDate: string;
  endDate: string;
  isCurrent: boolean;
  location?: string;
  grade?: string;
  relevantCoursework?: string[];
  achievements?: string[];
};

type ExperienceEntry = {
  id: string;
  jobTitle: string;
  company: string;
  location?: string;
  startDate: string;
  endDate: string;
  isCurrent: boolean;
  description?: string;
  bullets: string[];
  technologies?: string[];
};

type ProjectEntry = {
  id: string;
  name: string;
  description: string;
  technologies: string[];
  githubUrl?: string;
  demoUrl?: string;
  bullets: string[];
};

type SkillsProfile = {
  programmingLanguages: string[];
  frameworksLibraries: string[];
  toolsPlatforms: string[];
  databases: string[];
  cloudDevOps: string[];
  cybersecurity?: string[];
  machineLearning?: string[];
  softSkills: string[];
};

type CertificationEntry = {
  id: string;
  name: string;
  issuer: string;
  dateEarned?: string;
  credentialUrl?: string;
};

type VolunteerEntry = {
  id: string;
  role: string;
  organization: string;
  startDate?: string;
  endDate?: string;
  isCurrent?: boolean;
  description?: string;
  bullets?: string[];
};

type AwardEntry = {
  id: string;
  title: string;
  issuer?: string;
  date?: string;
  description?: string;
};

type LanguageEntry = {
  id: string;
  language: string;
  proficiency: string;
};

type ResumeTemplateId = "classic-ats" | "modern-clean" | "technical-engineer";

type TailoredResume = {
  personal: PersonalInfo;
  headline?: string;
  summary: string;
  education: TailoredEducationEntry[];
  experience: TailoredExperienceEntry[];
  projects: TailoredProjectEntry[];
  skills: TailoredSkillsProfile;
  certifications: CertificationEntry[];
  volunteerWork: VolunteerEntry[];
  awards: AwardEntry[];
  languages: LanguageEntry[];
  templateId: ResumeTemplateId;
};

Create these types in a dedicated file, for example:
src/types/resume.ts

